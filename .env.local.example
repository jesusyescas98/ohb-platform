# ========== SUPABASE CONFIGURATION ==========
# Get these from https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ========== AUTHENTICATION ==========
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-secret-key-min-32-characters-long-for-security

# Token expiry times (in seconds)
JWT_EXPIRY_ACCESS=3600
JWT_EXPIRY_REFRESH=604800

# ========== STRIPE CONFIGURATION ==========
# Test keys from https://dashboard.stripe.com/test/apikeys
NEXT_PUBLIC_STRIPE_PUBLIC_KEY=pk_test_51234567890abcdefghijklmnop
STRIPE_SECRET_KEY=sk_test_0987654321abcdefghijklmnopqrst
STRIPE_WEBHOOK_SECRET=whsec_test_1234567890abcdefghijklmnopqrstuvwxyz

# ========== EMAIL SERVICE (RESEND) ==========
# Get from https://resend.com/api-keys
RESEND_API_KEY=re_test_1234567890abcdefghijklmnopqrstuvwxyz
RESEND_FROM_EMAIL=noreply@ohbasesoriasyconsultorias.com

# ========== IMAGE OPTIMIZATION ==========
# Unsplash API for image fetching (optional)
NEXT_PUBLIC_UNSPLASH_ACCESS_KEY=your-unsplash-access-key
# Supabase Storage bucket name
NEXT_PUBLIC_STORAGE_BUCKET=ohb-properties

# ========== COMPANY DATA ==========
# These are NEXT_PUBLIC_ so they're safe to expose to the browser
NEXT_PUBLIC_COMPANY_NAME=OHB Asesorías y Consultorías
NEXT_PUBLIC_COMPANY_PHONE=+526561327685
NEXT_PUBLIC_COMPANY_EMAIL=jyeskas1111@gmail.com
NEXT_PUBLIC_COMPANY_ADDRESS=Tomás Fernández #7818, local 19, Col. Buscari, 32460 Juárez, Chihuahua

# ========== ANALYTICS & MONITORING ==========
# Google Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Sentry (error tracking) - optional
SENTRY_AUTH_TOKEN=your-sentry-token
SENTRY_ORG=your-org
SENTRY_PROJECT=your-project

# ========== FEATURE FLAGS ==========
NEXT_PUBLIC_ENABLE_ACADEMY=true
NEXT_PUBLIC_ENABLE_PAYMENTS=true
NEXT_PUBLIC_ENABLE_CHATBOT=true
NEXT_PUBLIC_ENABLE_MAPS=true

# ========== ENVIRONMENT ==========
NODE_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# ========== DEVELOPMENT TOOLS (dev only) ==========
# Set to true for verbose logging in development
NEXT_PUBLIC_DEBUG_MODE=false
