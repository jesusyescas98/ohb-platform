# ==========================================
# FASE D - Environment Variables
# AI Autonomous Integration + Hostinger Deployment
# ==========================================

# NEXT.JS CORE
NEXT_PUBLIC_SITE_URL=https://ohbasesoriasyconsultorias.com
NEXT_PUBLIC_APP_NAME=OHB Asesorías
NODE_ENV=production

# ==========================================
# SUPABASE (Free Tier)
# Setup: https://supabase.com → New Project
# ==========================================
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# ==========================================
# CLAUDE API (Fase D - IA Autonoma)
# Get key: https://console.anthropic.com/account/keys
# ==========================================
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# ==========================================
# STRIPE (Optional - Academy Payments)
# Get from: https://dashboard.stripe.com/apikeys
# ==========================================
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_YOUR_KEY
STRIPE_SECRET_KEY=sk_live_YOUR_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_SECRET

# ==========================================
# EMAIL SERVICE (Resend or SendGrid)
# ==========================================
RESEND_API_KEY=re_YOUR_KEY_HERE
# OR
SENDGRID_API_KEY=SG.YOUR_KEY_HERE

# ==========================================
# OHB BUSINESS CONFIG
# ==========================================
NEXT_PUBLIC_OHB_PHONE=+526561327685
NEXT_PUBLIC_OHB_EMAIL=support@ohb.com
NEXT_PUBLIC_OHB_ADDRESS=Tomás Fernández #7818, Col. Buscari, 32460 Juárez, Chihuahua
NEXT_PUBLIC_WHATSAPP_LINK=https://wa.me/526561327685

# ==========================================
# JWT SECRETS
# Generate: openssl rand -base64 32
# ==========================================
JWT_SECRET=YOUR_JWT_SECRET_32_CHARS_MIN
JWT_REFRESH_SECRET=YOUR_JWT_REFRESH_SECRET_32_CHARS_MIN

# ==========================================
# ANALYTICS (Optional - Vercel Analytics)
# ==========================================
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=YOUR_ID_HERE

# ==========================================
# DEFAULT ADMIN CREDENTIALS
# (Change on first login in production)
# ==========================================
NEXT_PUBLIC_DEMO_ADMIN_EMAIL=jyeskas1111@gmail.com
NEXT_PUBLIC_DEMO_ADMIN_PASSWORD=OHB2024Admin

