# ============================================================================
# OHB Platform — Environment Variables
# ============================================================================
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to version control
#
# Organization: OHB Asesorías y Consultorías
# Project: Real Estate Platform + Academy
# ============================================================================

# ========== SUPABASE CONFIGURATION ==========
# Get these from your Supabase project settings (https://supabase.com)

# Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase anon key (safe for browser use)
# Used in client-side code and respects RLS policies
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key (SECRET - server-side only!)
# DO NOT expose this to the browser
# Used in API routes to bypass RLS for admin operations
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ========== AUTHENTICATION ==========
# Secret key for signing JWT tokens
# Generate a strong random string: `openssl rand -base64 32`
JWT_SECRET=your-jwt-secret-here

# JWT token configuration (in seconds)
JWT_ACCESS_TOKEN_LIFETIME=900          # 15 minutes
JWT_REFRESH_TOKEN_LIFETIME=604800      # 7 days

# ========== STRIPE PAYMENT PROCESSING ==========
# Get from your Stripe dashboard (https://dashboard.stripe.com)

# Stripe public key (safe for browser use)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe secret key (server-side only)
STRIPE_SECRET_KEY=sk_test_...

# Stripe webhook secret (for handling webhooks)
STRIPE_WEBHOOK_SECRET=whsec_...

# ========== SUPABASE STORAGE ==========
# Storage bucket names (created in Supabase dashboard)

# Properties image bucket
NEXT_PUBLIC_STORAGE_BUCKET_PROPERTIES=properties

# Course materials bucket
NEXT_PUBLIC_STORAGE_BUCKET_COURSES=courses

# Certificates bucket
NEXT_PUBLIC_STORAGE_BUCKET_CERTIFICATES=certificates

# User profiles bucket
NEXT_PUBLIC_STORAGE_BUCKET_PROFILES=profiles

# ========== EMAIL CONFIGURATION ==========
# For transactional emails (account verification, password reset, etc.)

# Email service provider (sendgrid, mailgun, resend, etc.)
EMAIL_PROVIDER=resend

# Email API key
EMAIL_API_KEY=your-email-api-key

# Sender email address
EMAIL_FROM=noreply@ohbasesoriasyconsultorias.com
EMAIL_FROM_NAME="OHB Asesorías y Consultorías"

# ========== COMPANY INFORMATION ==========
# Used throughout the application

NEXT_PUBLIC_COMPANY_NAME="OHB Asesorías y Consultorías"
NEXT_PUBLIC_COMPANY_DOMAIN="ohbasesoriasyconsultorias.com"
NEXT_PUBLIC_COMPANY_WEBSITE="https://www.ohbasesoriasyconsultorias.com"
NEXT_PUBLIC_COMPANY_EMAIL="jyeskas1111@gmail.com"
NEXT_PUBLIC_COMPANY_PHONE="+526561327685"
NEXT_PUBLIC_COMPANY_WHATSAPP="https://wa.me/526561327685"

# ========== LOCATION & TIMEZONE ==========

NEXT_PUBLIC_DEFAULT_LOCATION="Ciudad Juárez, Chihuahua, México"
NEXT_PUBLIC_TIMEZONE="America/Mexico_City"

# ========== FEATURE FLAGS ==========
# Enable/disable features

NEXT_PUBLIC_ENABLE_ACADEMY=true
NEXT_PUBLIC_ENABLE_PAYMENTS=true
NEXT_PUBLIC_ENABLE_CHATBOT=true
NEXT_PUBLIC_ENABLE_MAPS=true

# ========== API CONFIGURATION ==========

# Base URL for API calls
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# API request timeout (milliseconds)
NEXT_PUBLIC_API_TIMEOUT=30000

# ========== THIRD-PARTY SERVICES ==========

# Google Maps API key (if using maps)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Google Analytics ID
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# Sentry error tracking (optional)
NEXT_PUBLIC_SENTRY_DSN=

# ========== DEVELOPMENT ONLY ==========
# These are used only in development environment

# Enable verbose logging
DEBUG=ohb:*

# Mock payment processing (skip Stripe in development)
NEXT_PUBLIC_MOCK_PAYMENTS=false

# Seed database on startup
SEED_DATABASE=false

# ========== DATABASE SEEDING ==========
# Seed initial data on first deployment

SEED_INITIAL_DATA=true
SEED_SAMPLE_PROPERTIES=true
SEED_SAMPLE_COURSES=true
SEED_SAMPLE_USERS=true

# ========== DEPLOYMENT ==========
# Set based on your deployment environment

NODE_ENV=development             # development, staging, production
NEXT_PUBLIC_ENVIRONMENT=dev      # dev, staging, prod

# ============================================================================
# INSTRUCTIONS:
# ============================================================================
#
# 1. Copy this file to .env.local:
#    cp .env.example .env.local
#
# 2. Get Supabase credentials:
#    - Go to https://supabase.com
#    - Create a new project or use existing
#    - Settings → API → Copy URL and API keys
#
# 3. Get Stripe credentials (for payments):
#    - Go to https://dashboard.stripe.com
#    - Copy Publishable and Secret keys
#    - Create webhook endpoint
#
# 4. Generate JWT secret:
#    openssl rand -base64 32
#
# 5. Configure email provider:
#    - Choose a provider (Resend, SendGrid, Mailgun, etc.)
#    - Add API key and configure sender email
#
# 6. Test locally:
#    npm run dev
#    The app should start on http://localhost:3000
#
# 7. For production, set all production-specific values
#    and deploy to your hosting platform
#
# ============================================================================
# SECURITY:
# ============================================================================
#
# ✅ Safe to use in browser (prefixed with NEXT_PUBLIC_):
#    - NEXT_PUBLIC_SUPABASE_URL
#    - NEXT_PUBLIC_SUPABASE_ANON_KEY
#    - NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY
#    - All other NEXT_PUBLIC_* variables
#
# ❌ NEVER expose to browser (server-side only):
#    - SUPABASE_SERVICE_ROLE_KEY
#    - STRIPE_SECRET_KEY
#    - JWT_SECRET
#    - STRIPE_WEBHOOK_SECRET
#    - EMAIL_API_KEY
#
# Use next/config or server components to access server-only vars.
#
# ============================================================================
